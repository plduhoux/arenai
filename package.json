{
  "name": "arenai",
  "version": "0.1.0",
  "description": "Secret Hitler played by LLMs - watch AI models bluff, vote, and legislate",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "preview": "npm run build && npm start"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.9.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "keywords": [
    "secret-hitler",
    "ai",
    "llm",
    "game-simulation",
    "anthropic",
    "claude"
  ],
  "license": "MIT"
}

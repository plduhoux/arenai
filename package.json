{
  "name": "arenai",
  "version": "0.1.0",
  "description": "LLMs play social deduction games against each other. Secret Dictator, Werewolf, Two Rooms and a Boom.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "preview": "npm run build && npm start"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.45.0",
    "better-sqlite3": "^11.9.1",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "keywords": [
    "arenai",
    "llm",
    "benchmark",
    "social-deduction",
    "secret-dictator",
    "werewolf",
    "two-rooms",
    "ai",
    "game-simulation"
  ],
  "license": "MIT"
}
